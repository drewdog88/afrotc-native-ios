# Copy to .env and fill in. NEVER commit the real .env.
# --- Database (REQUIRED — PostgreSQL/Neon only; there is NO local/SQLite fallback) ---
# App runtime uses the POOLED Neon connection string:
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST-pooler/neondb?sslmode=require
# Run Alembic migrations against the UNPOOLED (direct) host to avoid pgbouncer, e.g.:
#   DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST/neondb?sslmode=require uv run alembic upgrade head

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
# Fernet key for encrypting TOTP secrets at rest.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change-me-to-a-fernet-key

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- Bootstrap admin (created on first startup if no users exist) ---
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@det695.local
BOOTSTRAP_ADMIN_PASSWORD=change-me-on-first-login

# --- File storage ---
# "postgres" stores uploads as bytea in the DB (no extra service).
# "vercel_blob" uses Vercel Blob (set BLOB_READ_WRITE_TOKEN).
STORAGE_BACKEND=postgres
# BLOB_READ_WRITE_TOKEN=

# --- CORS (comma-separated origins for the web app) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Backup / cron auth ---
CRON_SECRET=change-me

# Native iOS app — not part of the web/API deploy
ios/

# Local Python/Node artifacts (Vercel installs fresh from requirements.txt / package.json)
.venv/
backend/.venv/
backend/alembic/
web/node_modules/
web/shots/
**/__pycache__/
**/*.pyc

# Screenshots & scratch — root-level only. A blanket `*.png` also strips the
# app's real source assets (web/src/assets/*.png), which Vite imports at build
# time; that breaks the build. web/shots/ (above) already covers screenshots.
/*.png
